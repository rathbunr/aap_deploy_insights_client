# =============================================================================
# Ansible Vault Variables Example
# =============================================================================
# Copy this file to vault.yml and encrypt it:
#   cp vault.yml.example vault.yml
#   ansible-vault encrypt vault.yml
#
# Then edit with:
#   ansible-vault edit vault.yml
# =============================================================================

# -----------------------------------------------------------------------------
# RHSM Registration Credentials
# -----------------------------------------------------------------------------
# Find your Organization ID at: https://console.redhat.com/settings/integrations
# Or run: subscription-manager identity (on an already registered system)
vault_rhc_organization: "1234567"

# Create activation keys at: https://console.redhat.com/insights/connector/activation-keys
# Activation keys should include:
#   - RHEL 9 content set
#   - Any additional repositories needed (e.g., Ansible Automation Platform)
vault_activation_key: "your-activation-key-name"

# -----------------------------------------------------------------------------
# Compliance Policy ID
# -----------------------------------------------------------------------------
# Create your compliance policy at: https://console.redhat.com/insights/compliance/scap-policies
# Steps:
#   1. Click "Create new policy"
#   2. Select "CIS Red Hat Enterprise Linux 9 Benchmark"
#   3. Choose "Level 1 - Server" or your required profile
#   4. Assign systems or system groups
#   5. Copy the policy UUID from the URL or policy details
#
# The policy ID is the UUID shown in the browser URL when viewing the policy:
# https://console.redhat.com/insights/compliance/scap-policies/{POLICY-UUID}
vault_compliance_policy_id: "00000000-0000-0000-0000-000000000000"
